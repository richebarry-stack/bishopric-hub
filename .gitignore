# Cloudflare config — contains your D1 database_id; copy wrangler.jsonc.example and fill in your values
wrangler.jsonc

# Wrangler local dev state (local SQLite, cache)
.wrangler/

# Claude Code project config
.claude/

# Data import/seed scripts — may contain personal ward data
scripts/

# Data import migrations — contain ward member names and event details
migrations/*_import.sql
migrations/*_seed.sql

# Environment files — never commit credentials or secrets
.env
.env.*

# Data exports — CSV/JSON dumps may contain member data
*.csv
data-export/
exports/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
