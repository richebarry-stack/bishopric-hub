migrations/0043_speakers_2025_2026.sql
migrations/0044_ward_members.sql
migrations/0045_sync_ward_members.sql
migrations/0047_ward_member_birthdates.sql
migrations/0048_import_prayers.sql

# Environment files — never commit credentials or secrets
.env
.env.*

# Data exports — CSV/JSON dumps may contain member data
*.csv
data-export/
exports/

