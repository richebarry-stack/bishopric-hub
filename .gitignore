# Wrangler local dev state (local SQLite, cache)
.wrangler/

# Claude Code project config
.claude/

# Data import/seed scripts — may contain personal ward data
scripts/

# Data import/seed migrations — contain ward member names and event details
migrations/*_import.sql
migrations/*_seed.sql

# Migrations with personal ward data (member names, interview records, birthdates, prayer history)
migrations/0036_interview_youth_rename.sql
