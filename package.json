{
  "name": "bishopric-hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "wrangler pages dev --d1 DB=bishopric-hub-db -- vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "wrangler pages dev dist --d1 DB=bishopric-hub-db",
    "db:init": "wrangler d1 execute bishopric-hub-db --local --file=migrations/0001_schema.sql",
    "db:seed": "wrangler d1 execute bishopric-hub-db --local --file=scripts/seed.sql",
    "db:import": "bash scripts/import-coda.sh > scripts/import-data.sql && wrangler d1 execute bishopric-hub-db --local --file=scripts/import-data.sql",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wrangler": "^4.103.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260617.1": true
  }
}
